// Configuraciones de servidor que Next.js no debe validar en el export estático
export const dynamic = 'force-dynamic';
export const runtime = 'nodejs';
export const fetchCache = 'force-no-store';

import { NextResponse } from 'next/server';
// Usamos ruta relativa para asegurar que TypeScript lo encuentre sin problemas
import { adminRtdb } from '../../../../lib/firebase-admin';

export async function handleCleanup(req: Request) {
  try {
    // Validamos que la referencia a la Realtime Database exista
    if (!adminRtdb) {
      return NextResponse.json({ error: "Firebase DB (Admin) no inicializada" }, { status: 500 });
    }

    // Calcular el timestamp de hace 7 días (168 horas)
    const sieteDiasAtras = Date.now() - (7 * 24 * 60 * 60 * 1000);
    let deletedCount = 0;
    
    // 1. Limpieza de 'historial_navegacion' (URLs Visitadas)
    const historialRef = adminRtdb.ref('historial_navegacion');
    const dispositivosSnapshot = await historialRef.once('value');

    if (dispositivosSnapshot.exists()) {
      const dispositivos = dispositivosSnapshot.val() as Record<string, any>;
      for (const [deviceId, logs] of Object.entries(dispositivos)) {
        if (logs && typeof logs === 'object') {
          for (const [logId, logData] of Object.entries(logs as Record<string, any>)) {
            // Verificación segura: usamos el timestamp del objeto o el ID si es un número
            const timestamp = (logData as any)?.timestamp || Number(logId);
            if (timestamp && timestamp < sieteDiasAtras) {
              await historialRef.child(deviceId).child(logId).remove();
              deletedCount++;
            }
          }
        }
      }
    }

    // 2. Limpieza de 'system_logs' en 'dispositivos' (Registros de sistema)
    const dispRef = adminRtdb.ref('dispositivos');
    const dSnap = await dispRef.once('value');
    
    if (dSnap.exists()) {
      const dObj = dSnap.val() as Record<string, any>;
      for (const [dId, data] of Object.entries(dObj)) {
        if (data && typeof data === 'object' && 'system_logs' in data) {
          const systemLogs = (data as any).system_logs;
          if (systemLogs && typeof systemLogs === 'object') {
            for (const [tsStr, log] of Object.entries(systemLogs as Record<string, any>)) {
              const timestamp = Number(tsStr);
              if (timestamp && timestamp < sieteDiasAtras) {
                await dispRef.child(dId).child('system_logs').child(tsStr).remove();
                deletedCount++;
              }
            }
          }
        }
      }
    }

    return NextResponse.json({ 
        success: true, 
        deleted: deletedCount, 
        message: `Mantenimiento exitoso. Se han purgado ${deletedCount} registros antiguos de la RTDB.` 
    });

  } catch (error: any) {
    console.error("Error en Acción de Limpieza RTDB:", error);
    return NextResponse.json({ error: error.message }, { status: 500 });
  }
}